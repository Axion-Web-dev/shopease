# Database Connection (Required)
DATABASE_URL="postgresql://user:password@localhost:5432/shopease?schema=public"

# Session Secret (Required) - MUST be at least 32 characters
# Generate a strong random string: openssl rand -base64 32
# IMPORTANT: Change this in production! The app will not start without it.
SESSION_SECRET="change-this-to-a-strong-random-secret-minimum-32-characters"

# Node Environment
NODE_ENV="development"

# CORS - Comma-separated list of allowed origins (Required for production)
# Example: "https://yourdomain.com,https://www.yourdomain.com"
# DO NOT use "*" in production - this is a security risk
ALLOWED_ORIGINS="http://localhost:3000"

# Redis for distributed rate limiting (Recommended for production/Vercel)
# For Vercel, use Vercel KV or Upstash Redis
# Without this, rate limiting falls back to in-memory (won't work on serverless)
REDIS_URL="redis://localhost:6379"

# Rate limiting configuration
RATE_LIMIT_WINDOW_MS=900000  # 15 minutes in milliseconds
RATE_LIMIT_MAX_ATTEMPTS=5    # Max attempts per window
